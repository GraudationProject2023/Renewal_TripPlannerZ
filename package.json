{
  "name": "TripPlannerZ",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm lint:root && turbo run lint",
    "lint:root": "eslint eslint.config.js commitlint.config.js lint-staged.config.js scripts/**/*.mjs",
    "lint:fix": "pnpm lint:root:fix && turbo run lint -- --fix",
    "lint:root:fix": "eslint eslint.config.js commitlint.config.js lint-staged.config.js scripts/**/*.mjs --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
   "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "msw": "^2.10.3",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.28.0",
    "webpack": "^5.104.1"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
